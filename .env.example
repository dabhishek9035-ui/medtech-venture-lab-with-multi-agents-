# Copy this file to .env and fill in your key
GOOGLE_API_KEY= YOUR_API_KEY_HERE

# Model to use across all agents (free tier)
GEMINI_MODEL=gemini-2.0-flash

# Optional: tweak agent temperature (0.0 = deterministic, 1.0 = creative)
AGENT_TEMPERATURE=0.3

# Agent execution mode:
#   false (default) = sequential with delay — safe for free tier (2 RPM)
#   true            = parallel fan-out via Send — use with paid quota only
PARALLEL_AGENTS=false

# Delay in seconds between sequential agent calls (default 35s = safe under 2 RPM)
# Set to 0 if you have a paid API key
AGENT_DELAY_SECONDS=35